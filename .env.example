# ============================================================
# TEA Group — Environment variables
# Copy this file to `.env` (root) and fill in real values.
#   pnpm does NOT auto-load .env at root for apps; the web app
#   loads its own apps/web/.env. Keep BOTH in sync during dev.
# ------------------------------------------------------------
# RULES:
#   - Anything prefixed with NEXT_PUBLIC_ is exposed to the browser.
#     NEVER put secrets (service role, API keys) under NEXT_PUBLIC_*.
#   - Service-role + Anthropic keys are SERVER-SIDE ONLY.
# ============================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase ----
# Project > Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://bsmxfrnpplkkuuapbguc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJzbXhmcm5wcGxra3V1YXBiZ3VjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1NzczNjYsImV4cCI6MjA5OTE1MzM2Nn0.PTlQoUBIPM79FtQxY10VDgHEG5kJjitbTJDqtOYnAog

# Service role — SERVER-SIDE ONLY. Used by Route Handlers (HDVH parser,
# privileged writes). Must NEVER appear in the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- AI Provider (HDVH parser) ----
# Available providers: ollama (local), openrouter (free tier), anthropic (paid), gemini (deprecated)
# SERVER-SIDE ONLY.
AI_PROVIDER=ollama

# Ollama — local, free, no API key needed (runs on http://localhost:11434)
OLLAMA_MODEL=qwen2.5vl:7b
# OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter — free tier API access to multiple AI models
# Get API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_BASE_URL=https://openrouter.ai

# Anthropic — direct Claude API (paid)
# Get API key from https://console.anthropic.com
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini — DEPRECATED (no longer supported)
# GEMINI_API_KEY=

# ---- Email (contact form) ----
# Preferred provider: Resend (https://resend.com). SERVER-SIDE ONLY.
RESEND_API_KEY=your-resend-api-key
# Default recipient for contact messages (editable later via Admin Settings).
CONTACT_TO_EMAIL=contact@teagroup.vn
# Verified sender address used by Resend.
MAIL_FROM="TEA Group <noreply@teagroup.vn>"

# SMTP fallback (used only when RESEND_API_KEY is empty)
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=

# ---- Local Supabase (optional, for `supabase start`) ----
# Leave blank to use the values printed by `supabase status`.
# SUPABASE_DB_URL=
