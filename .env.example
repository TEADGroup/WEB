# ============================================================
# TEA Group — Environment variables
# Copy this file to `.env` (root) and fill in real values.
#   pnpm does NOT auto-load .env at root for apps; the web app
#   loads its own apps/web/.env. Keep BOTH in sync during dev.
# ------------------------------------------------------------
# RULES:
#   - Anything prefixed with NEXT_PUBLIC_ is exposed to the browser.
#     NEVER put secrets (service role, API keys) under NEXT_PUBLIC_*.
#   - Service-role + Anthropic keys are SERVER-SIDE ONLY.
# ============================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase ----
# Project > Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role — SERVER-SIDE ONLY. Used by Route Handlers (HDVH parser,
# privileged writes). Must NEVER appear in the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- Anthropic (AI HDVH parser) ----
# Get from https://console.anthropic.com/. SERVER-SIDE ONLY.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ---- Email (contact form) ----
# Preferred provider: Resend (https://resend.com). SERVER-SIDE ONLY.
RESEND_API_KEY=your-resend-api-key
# Default recipient for contact messages (editable later via Admin Settings).
CONTACT_TO_EMAIL=contact@teagroup.vn
# Verified sender address used by Resend.
MAIL_FROM="TEA Group <noreply@teagroup.vn>"

# SMTP fallback (used only when RESEND_API_KEY is empty)
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=

# ---- Local Supabase (optional, for `supabase start`) ----
# Leave blank to use the values printed by `supabase status`.
# SUPABASE_DB_URL=
